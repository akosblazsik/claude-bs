{
  "name": "multiagent-nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ./app ./components ./lib",
    "lint:fix": "biome check --write ./app ./components ./lib",
    "format": "biome format --write ./app ./components ./lib",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "next": "^15.2",
    "react": "^19.0",
    "react-dom": "^19.0",
    "class-variance-authority": "^0.7",
    "clsx": "^2.1",
    "tailwind-merge": "^3.0",
    "lucide-react": "^0.474"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5.7",
    "tailwindcss": "^4.0",
    "@tailwindcss/postcss": "^4.0",
    "postcss": "^8.5",
    "vitest": "^3.0",
    "@vitejs/plugin-react": "^4.3",
    "@playwright/test": "^1.50"
  }
}
